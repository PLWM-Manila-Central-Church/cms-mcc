NODE_ENV=production

# TiDB Cloud public endpoint settings.
DB_HOST=<tidb-host>
DB_PORT=4000
DB_NAME=<tidb-database>
DB_USER=<tidb-user>
DB_PASSWORD=<tidb-password>
DB_SSL=true

JWT_SECRET=<render-generated-or-rotated-secret>
JWT_EXPIRES_IN=8h
REFRESH_TOKEN_SECRET=<render-generated-or-rotated-secret>
REFRESH_TOKEN_EXPIRES_IN=7d
BCRYPT_ROUNDS=10

FRONTEND_URL=https://cms-mcc.vercel.app
ALLOWED_ORIGIN=https://cms-mcc.vercel.app

BREVO_API_KEY=<brevo-api-key>
SMTP_FROM="PLWM-MCC <noreply@example.com>"
MAX_FILE_SIZE_MB=25
